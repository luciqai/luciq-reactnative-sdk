{
  "migrationMethods": [
    {
      "name": "Instabug to Luciq Text Replacements",
      "description": "Replace all instances of Instabug with Luciq",
      "searchReplace": [
        { "search": "Instabug", "replacement": "Luciq" },
        { "search": "instabug", "replacement": "luciq" },
        { "search": "INSTABUG", "replacement": "LUCIQ" },
        { "search": "IBG", "replacement": "LCQ" },
        { "search": "ibg", "replacement": "lcq" }
      ],
      "targetExtensions": [
        ".h",
        ".m",
        ".java",
        ".kt",
        ".ts",
        ".tsx",
        ".js",
        ".jsx"
      ],
      "ignoredDirs": [
        "node_modules",
        "build",
        "Pods",
        "vendor",
        ".git",
        "dist",
        "coverage",
        ".next",
        ".nuxt",
        "target"
      ],
      "enabled": true
    },
    {
      "name": "Package Name Updates",
      "description": "Update package names and references",
      "searchReplace": [
        { "search": "com.instabug", "replacement": "ai.luciq" },
        { "search": "com.instabug.reactlibrary", "replacement": "ai.luciq.reactlibrary" },
        { "search": "RNInstabug", "replacement": "RNLuciq" },
        { "search": "rninstabug", "replacement": "rnluciq" }
      ],
      "targetExtensions": [
        ".java",
        ".kt",
        ".xml",
        ".gradle",
        ".properties",
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".json"
      ],
      "ignoredDirs": [
        "node_modules",
        "build",
        "Pods",
        "vendor",
        ".git",
        "dist",
        "coverage"
      ],
      "enabled": true
    },
    {
      "name": "File Extension Cleanup",
      "description": "Clean up file extensions and references",
      "searchReplace": [
        { "search": ".instabug", "replacement": ".luciq" },
        { "search": "_instabug", "replacement": "_luciq" },
        { "search": "instabug_", "replacement": "luciq_" }
      ],
      "targetExtensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx"
      ],
      "ignoredDirs": [
        "node_modules",
        "build",
        "Pods",
        "vendor",
        ".git",
        "dist",
        "coverage"
      ],
      "enabled": true
    },
    {
      "name": "Dependency Version Updates",
      "description": "Update dependency versions from Instabug to Luciq",
      "searchReplace": [
        {
          "search": "com\\.instabug\\.library:instabug:[0-9]+\\.[0-9]+\\.[0-9]+",
          "replacement": "ai.luciq.library:luciq:18.0.0",
          "isRegex": true
        },
        {
          "search": "com\\.instabug\\.library:instabug:[0-9]+\\.[0-9]+\\.[0-9]+-.*",
          "replacement": "ai.luciq.library:luciq:18.0.0",
          "isRegex": true
        },
        {
          "search": "com\\.instabug\\.library:instabug:[0-9]+\\.[0-9]+\\.[0-9]+-SNAPSHOT",
          "replacement": "ai.luciq.library:luciq:18.0.0",
          "isRegex": true
        }
      ],
      "targetExtensions": [
        ".gradle",
        ".properties",
        ".xml",
        ".json"
      ],
      "ignoredDirs": [
        "node_modules",
        "build",
        "Pods",
        "vendor",
        ".git",
        "dist",
        "coverage"
      ],
      "enabled": true
    }
  ],
  "defaultOptions": {
    "dryRun": false,
    "silent": false
  }
}
